@prefix dbr: <http://dbpedia.org/resource/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix hi: <https://w3id.org/hi-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

schema1:PropertyValue a owl:Class ;
    rdfs:label "Property Value"@en ;
    rdfs:comment "A Schema.org class representing a specific property-value pair, often used for metadata or structured descriptions."@en .

hi: a owl:Ontology ;
    dc:description "Conceptual model of Hybrid Intelligence: agents, teams, goals, tasks, capabilities, methods, evaluations, context, and ethical phenomena."@en ;
    dc:license <https://creativecommons.org/licenses/by/4.0/> ;
    dc:title "The Hybrid Intelligence (HI) Ontology"@en ;
    dcterms:created "2025-10-01"^^xsd:date ;
    vann:preferredNamespacePrefix "hi" ;
    vann:preferredNamespaceUri "https://w3id.org/hi-ontology#" ;
    owl:versionInfo "2.0.0" .

hi:AdaptiveCybersecurityUseCase a hi:UseCase ;
    rdfs:label "Adaptive cybersecurity response"@en ;
    hi:hasDomain hi:SecurityDomain ;
    hi:hasHITeam hi:CybersecurityResponseTeam .

hi:AlexLearningSupportUseCase a hi:UseCase ;
    hi:hasDomain hi:EducationDomain ;
    hi:hasHITeam hi:AlexLearningSupportTeam .

hi:ArchivalCurationUseCase a hi:UseCase ;
    rdfs:label "Archival footage curation"@en ;
    hi:hasDomain hi:CulturalHeritageDomain ;
    hi:hasHITeam hi:ArchivalCurationTeam .

hi:AxiomWeakening a hi:Method ;
    rdfs:label "Axiom weakening"@en ;
    owl:sameAs dbr:Ontology_learning .

hi:BrainAgePredictionUseCase a hi:UseCase ;
    rdfs:label "Explainable brain age prediction"@en ;
    hi:hasDomain hi:HealthcareDomain ;
    hi:hasHITeam hi:BrainAgePredictionTeam .

hi:CausalDiscoveryUseCase a hi:UseCase ;
    rdfs:label "Causal discovery through repeated interventions"@en ;
    hi:hasDomain hi:CausalDiscoveryDomain ;
    hi:hasHITeam hi:CausalDiscoveryTeam .

hi:ClinicalOutcomeMetric a hi:Metric ;
    rdfs:label "Clinical outcomes"@en .

hi:ClinicalRecommendationExecution_01 a hi:TaskExecution ;
    hi:hasInputData hi:ClinicalCaseData ;
    hi:hasInteractionEpisode hi:ClinicalAdviceTakingInteraction_01 ;
    hi:hasOutputData hi:ClinicalRecommendationData ;
    hi:performedBy hi:ClinicalAIDecisionSupportTool,
        hi:Clinician ;
    hi:realizesTask hi:ClinicalRecommendationTask ;
    hi:towardsGoal hi:SupportClinicalDecisionMakingGoal .

hi:ClinicalUncertaintyCommunicationUseCase a hi:UseCase ;
    hi:hasDomain hi:HealthcareDomain ;
    hi:hasHITeam hi:ClinicalDecisionSupportTeam .

hi:CoCreation a hi:Method ;
    owl:sameAs dbr:Co-creation,
        wd:Q5132513 .

hi:CodeAssistantUseCase a hi:UseCase ;
    hi:hasDomain hi:SoftwareEngineeringDomain ;
    hi:hasHITeam hi:CodeAssistantTeam .

hi:CodeGenerationExecution_01 a hi:TaskExecution ;
    hi:hasInputData hi:PromptSpecificationData ;
    hi:hasInteractionEpisode hi:CodeGenerationInteraction_01 ;
    hi:hasOutputData hi:GeneratedCodeData ;
    hi:performedBy hi:CodeGenerationController ;
    hi:realizesTask hi:CodeGenerationTask ;
    hi:towardsGoal hi:SupportCodeAuthoringGoal ;
    hi:usesModel hi:GPT_4o_mini .

hi:CollaborationBased a hi:Method .

hi:CollaborativeGameplayUseCase a hi:UseCase ;
    hi:hasDomain hi:EducationDomain ;
    hi:hasHITeam hi:CollaborativeGameplayTeam .

hi:ContributionBased a hi:Method .

hi:DecisionEvent_CollaborativeGameStrategy a hi:TaskExecution ;
    rdfs:label "Decision event: collaborative game strategy"@en ;
    hi:hasInputData hi:Data_TrustGameLogs,
        hi:Evidence_GameInteractionLogs ;
    hi:hasInteractionEpisode hi:Interaction_CollaborativeGameStrategy ;
    hi:hasOutputData hi:Justification_TrustFactorModel,
        hi:Recommendation_CollaborationStrategy ;
    hi:performedBy hi:AI_TrustGameTeammate,
        hi:Human_User ;
    hi:realizesTask hi:Task_CollaborativeGameStrategy .

hi:DecisionEvent_EnvironmentReconstruction a hi:TaskExecution ;
    rdfs:label "Decision event: environment reconstruction"@en ;
    hi:hasInputData hi:Data_ArchaeologyRecords,
        hi:Evidence_ArchaeologicalRecords ;
    hi:hasInteractionEpisode hi:Interaction_EnvironmentReconstruction ;
    hi:hasOutputData hi:Justification_DataDrivenReconstruction,
        hi:Recommendation_ReconstructionHypothesis ;
    hi:performedBy hi:AI_PaleoReconstructionAssistant,
        hi:Human_Researcher ;
    hi:realizesTask hi:Task_EnvironmentReconstruction .

hi:DecisionEvent_GazeInteraction1 a hi:TaskExecution ;
    rdfs:label "Decision event: gaze interaction"@en ;
    hi:hasInputData hi:Data_GazeTrackingStream,
        hi:Evidence_GazeAttentionData ;
    hi:hasInteractionEpisode hi:Interaction_GazeInteraction1 ;
    hi:hasOutputData hi:Justification_GazeBasedPersonalization,
        hi:Recommendation_GazePersonalizedResponse ;
    hi:performedBy hi:AI_GazeAwareConversationalAgent,
        hi:Human_User ;
    hi:realizesTask hi:Task_GazePersonalization .

hi:DecisionEvent_LifestyleRecommendation a hi:TaskExecution ;
    rdfs:label "Decision event: lifestyle recommendation"@en ;
    hi:hasInputData hi:Data_LifestyleLogs,
        hi:Evidence_LifestyleLogs ;
    hi:hasInteractionEpisode hi:Interaction_LifestyleRecommendation ;
    hi:hasOutputData hi:Justification_BehavioralAnalysis,
        hi:Recommendation_LifestyleChange ;
    hi:performedBy hi:AI_SocialHealthCoach,
        hi:Human_User ;
    hi:realizesTask hi:Task_LifestyleRecommendation .

hi:DecisionEvent_MoralJudgement a hi:TaskExecution ;
    rdfs:label "Decision event: moral judgement"@en ;
    hi:hasInputData hi:Data_MoralDilemmaSet,
        hi:Evidence_MoralDataset ;
    hi:hasInteractionEpisode hi:Interaction_MoralJudgement ;
    hi:hasOutputData hi:Justification_MoralReasoning,
        hi:Recommendation_MoralChoice ;
    hi:performedBy hi:AI_LLM_MoralReasoner,
        hi:Human_Expert ;
    hi:realizesTask hi:Task_MoralJudgementSupport .

hi:DecisionEvent_PolicySimulation a hi:TaskExecution ;
    rdfs:label "Decision event: policy simulation"@en ;
    hi:hasInputData hi:Data_PolicySimulationParameters,
        hi:Evidence_SimulationParameters ;
    hi:hasInteractionEpisode hi:Interaction_PolicySimulation ;
    hi:hasOutputData hi:Justification_SimulationResults,
        hi:Recommendation_PolicyOption ;
    hi:performedBy hi:AI_PolicySimulationAgent,
        hi:Human_Expert ;
    hi:realizesTask hi:Task_PolicySimulation .

hi:DecisionEvent_TrustCalibration a hi:TaskExecution ;
    rdfs:label "Decision event: trust calibration"@en ;
    hi:hasInputData hi:Data_EEGSignals,
        hi:Evidence_EEGSignalsUsed ;
    hi:hasInteractionEpisode hi:Interaction_TrustCalibration ;
    hi:hasOutputData hi:Justification_EEGSignalAnalysis,
        hi:Recommendation_TrustAdjustment ;
    hi:performedBy hi:AI_EEG_TrustCalibrationSystem,
        hi:Human_User ;
    hi:realizesTask hi:Task_TrustCalibration .

hi:DesignerUser a foaf:Person,
        hi:HumanAgent ;
    hi:hasCapability hi:Communication,
        hi:Creativity .

hi:DrivingRecommendationExecution_01 a hi:TaskExecution ;
    hi:hasInputData hi:DrivingSensorData ;
    hi:hasInteractionEpisode hi:DrivingSupportInteraction_01 ;
    hi:hasOutputData hi:DrivingRecommendationData ;
    hi:performedBy hi:TeslaAutosteer ;
    hi:realizesTask hi:RecommendationTask ;
    hi:towardsGoal hi:SupportSafeDrivingGoal .

hi:DrivingSupportUseCase a hi:UseCase ;
    hi:hasDomain hi:MobilityDomain ;
    hi:hasHITeam hi:DrivingSupportTeam .

hi:FaceMatchingDecisionSupportUseCase a hi:UseCase ;
    rdfs:label "Human–AI face matching decision support"@en ;
    hi:hasDomain hi:BiometricsAndForensicsDomain ;
    hi:hasHITeam hi:FaceMatchingHITeam .

hi:GameplayCoordinationExecution_01 a hi:TaskExecution ;
    hi:hasInputData hi:GameStateData ;
    hi:hasInteractionEpisode hi:GameplayInteraction_01 ;
    hi:hasOutputData hi:GameplayCoordinationData ;
    hi:performedBy hi:RobotAgent ;
    hi:realizesTask hi:JointActionTask ;
    hi:towardsGoal hi:EnableCollaborativeGameplayGoal .

hi:GrammarlyAutocorrect a hi:ArtificialAgent ;
    owl:sameAs wd:Q5595569 ;
    hi:hasCapability hi:Communication,
        hi:Transparency .

hi:HILLInspectionUseCase a hi:UseCase ;
    rdfs:label "Human in the Latent Loop model inspection"@en ;
    hi:hasDomain hi:ArtificialIntelligenceResearchDomain ;
    hi:hasHITeam hi:HILLInspectionTeam .

hi:HybridHumanPolicyModelingUseCase a hi:UseCase ;
    rdfs:label "Hybrid human policy modeling with simulations"@en ;
    hi:hasDomain hi:PublicPolicyDomain ;
    hi:hasHITeam hi:HybridHumanPolicyTeam .

hi:KnowledgeFormalizationExecution_01 a hi:TaskExecution ;
    hi:hasInputData hi:FormalizationInputData ;
    hi:hasInteractionEpisode hi:KnowledgeAcquisitionInteraction_01 ;
    hi:hasOutputData hi:FormalRuleOutputData ;
    hi:performedBy hi:FormalizationAssistantAgent,
        hi:Human_Expert ;
    hi:realizesTask hi:FormalRuleGenerationTask ;
    hi:towardsGoal hi:FormalizeKnowledgeGoal .

hi:KnowledgeFormalizationUseCase a hi:UseCase ;
    hi:hasDomain hi:KnowledgeEngineeringDomain ;
    hi:hasHITeam hi:KnowledgeFormalizationTeam .

hi:LongTermChatbotMemoryUseCase a hi:UseCase ;
    rdfs:label "Graph-based long-term chatbot memory"@en ;
    hi:hasDomain hi:ConversationalAIDomain ;
    hi:hasHITeam hi:LongTermChatbotMemoryTeam .

hi:LongTermDialogueExecution_01 a hi:TaskExecution ;
    hi:hasInputData hi:LongMemo5Dataset ;
    hi:hasInteractionEpisode hi:MemoryAugmentedDialogueInteraction_01 ;
    hi:hasOutputData hi:DialogueResponseData ;
    hi:performedBy hi:Chatbot,
        hi:Human_User ;
    hi:realizesTask hi:LongTermDialogueTask ;
    hi:towardsGoal hi:SustainLongTermDialogueGoal ;
    hi:usesModel hi:GraphMemoMemorySystem .

hi:LongTermMemoryChatbotUseCase a hi:UseCase ;
    hi:hasDomain hi:ConversationalAIDomain ;
    hi:hasHITeam hi:LongTermDialogueTeam .

hi:Multimodal a hi:Method .

hi:NeuroSymbolic a hi:Method ;
    owl:sameAs dbr:Neuro-symbolic_AI,
        wd:Q97477039 .

hi:NeurosymbolicOntologyEvolutionUseCase a hi:UseCase ;
    hi:hasDomain hi:KnowledgeEngineeringDomain ;
    hi:hasHITeam hi:OntologyEvolutionTeam .

hi:OntologyRepairExecution_01 a hi:TaskExecution ;
    hi:hasInputData hi:CandidateKnowledgeBuffer ;
    hi:hasInteractionEpisode hi:NeurosymbolicRepairInteraction_01 ;
    hi:hasOutputData hi:OntologyRepairSuggestionData ;
    hi:performedBy hi:Human_Expert,
        hi:LLM_Agent ;
    hi:realizesTask hi:OntologyRepairTask ;
    hi:towardsGoal hi:MaintainOntologyQualityGoal .

hi:PersonalizedLearningSupportExecution_01 a hi:TaskExecution ;
    hi:hasInputData hi:LearnerProfileData ;
    hi:hasInteractionEpisode hi:CollaborativeLearningPlanInteraction_01,
        hi:PositiveReinforcementInteraction_01,
        hi:ProgressReportingInteraction_01 ;
    hi:hasOutputData hi:LearningSupportRecommendationData ;
    hi:performedBy hi:AssistiveRobot,
        hi:TeacherUser,
        hi:Therapist ;
    hi:realizesTask hi:PersonalizedLearningSupportTask ;
    hi:towardsGoal hi:SupportPersonalizedLearningGoal .

hi:ProteinDiscoveryUseCase a hi:UseCase ;
    rdfs:label "Protein discovery with human-AI collaboration"@en ;
    hi:hasDomain hi:HealthcareDomain ;
    hi:hasHITeam hi:ProteinDiscoveryTeam .

hi:PublicPolicySimulationUseCase a hi:UseCase ;
    rdfs:label "Participatory public policy simulation"@en ;
    hi:hasDomain hi:GovernanceDomain ;
    hi:hasHITeam hi:PolicySimulationTeam .

hi:RobotAssistedLearningUseCase a hi:UseCase ;
    rdfs:label "Robot-assisted learning support"@en ;
    hi:hasDomain hi:EducationDomain ;
    hi:hasHITeam hi:RobotAssistedLearningTeam .

hi:Symbolic a hi:Method .

hi:TrustCalibrationUseCase a hi:UseCase ;
    rdfs:label "EEG-based trust calibration assessment"@en ;
    hi:hasDomain hi:HealthcareDomain ;
    hi:hasHITeam hi:TrustCalibrationTeam .

hi:VRConversationalInteractionUseCase a hi:UseCase ;
    rdfs:label "Gaze-aware conversational interaction in VR"@en ;
    hi:hasDomain hi:VirtualRealityDomain ;
    hi:hasHITeam hi:VRDialogueTeam .

hi:VoiceToTextTask a hi:Task ;
    hi:requiresCapability hi:Communication .

hi:evaluatedBy a owl:ObjectProperty ;
    rdfs:label "evaluated by" ;
    rdfs:comment "Execution is evaluated by a defined evaluation."@en ;
    rdfs:domain hi:TaskExecution ;
    rdfs:range hi:Evaluation .

hi:executesTask a owl:ObjectProperty ;
    rdfs:label "executes task" ;
    rdfs:comment "Agent executes a task (derivable from Agent→Execution→Task)."@en ;
    rdfs:domain hi:Agent ;
    rdfs:range hi:Task ;
    rdfs:subPropertyOf hi:isAssignedToTask ;
    owl:propertyChainAxiom ( hi:performsExecution hi:realizesTask ) .

hi:hasAgentConcept a owl:ObjectProperty ;
    rdfs:label "has agent concept" ;
    rdfs:comment "Links an agent to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Agent ;
    rdfs:range skos:Concept .

hi:hasAlternativeHypothesis a owl:DatatypeProperty ;
    rdfs:label "has alternative hypothesis"@en ;
    rdfs:comment "Stores the textual formulation of the alternative hypothesis of an experiment."@en ;
    rdfs:domain hi:Experiment ;
    rdfs:range xsd:string .

hi:hasCapabilityConcept a owl:ObjectProperty ;
    rdfs:label "has capability concept" ;
    rdfs:comment "Links a capability to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Capability ;
    rdfs:range skos:Concept .

hi:hasConstraintConcept a owl:ObjectProperty ;
    rdfs:label "has constraint concept" ;
    rdfs:comment "Specifies the constraint using a concept in the HINT thesaurus."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hi:Context hi:HITeam hi:Agent ) ] ;
    rdfs:range skos:Concept .

hi:hasContextConcept a owl:ObjectProperty ;
    rdfs:label "has context concept" ;
    rdfs:comment "Links a context to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Context ;
    rdfs:range skos:Concept .

hi:hasDomain a owl:ObjectProperty ;
    rdfs:label "has domain" ;
    rdfs:comment "Links a use case to a domain."@en ;
    rdfs:domain hi:UseCase ;
    rdfs:range hi:Domain .

hi:hasDomainConcept a owl:ObjectProperty ;
    rdfs:label "has domain concept" ;
    rdfs:comment "Links a domain to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Domain ;
    rdfs:range skos:Concept .

hi:hasEvaluationConcept a owl:ObjectProperty ;
    rdfs:label "has evaluation concept" ;
    rdfs:comment "Links an evaluation to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Evaluation ;
    rdfs:range skos:Concept .

hi:hasExecutionConcept a owl:ObjectProperty ;
    rdfs:label "has execution concept" ;
    rdfs:comment "Links an experiment to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:TaskExecution ;
    rdfs:range skos:Concept .

hi:hasExperiment a owl:ObjectProperty ;
    rdfs:label "has experiment" ;
    rdfs:comment "An evaluation has an experiment."@en ;
    rdfs:domain hi:Evaluation ;
    rdfs:range hi:Experiment .

hi:hasExperimentConcept a owl:ObjectProperty ;
    rdfs:label "has experiment concept" ;
    rdfs:comment "Links an experiment to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Experiment ;
    rdfs:range skos:Concept .

hi:hasGoal a owl:ObjectProperty ;
    rdfs:label "has goal" ;
    rdfs:comment "An HI team pursues one or more goals."@en ;
    rdfs:domain hi:HITeam ;
    rdfs:range hi:Goal .

hi:hasGoalConcept a owl:ObjectProperty ;
    rdfs:label "has goal concept" ;
    rdfs:comment "Links a goal to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Goal ;
    rdfs:range skos:Concept .

hi:hasHITeam a owl:ObjectProperty ;
    rdfs:label "has HI team" ;
    rdfs:comment "A use case introduces a hybrid intelligence team."@en ;
    rdfs:domain hi:UseCase ;
    rdfs:range hi:HITeam .

hi:hasInputData a owl:ObjectProperty ;
    rdfs:label "has input data" ;
    rdfs:comment "A model or task execution takes specific input data."@en ;
    rdfs:domain hi:Model,
        hi:TaskExecution ;
    rdfs:range hi:Data .

hi:hasInteractionEpisode a owl:ObjectProperty ;
    rdfs:label "has interaction episode" ;
    rdfs:comment "Identifies moments of interaction (e.g., dialogue, negotiation, or guidance) that unfold within the execution of a task."@en ;
    rdfs:domain hi:TaskExecution ;
    rdfs:range hi:Interaction .

hi:hasInteractionIntentConcept a owl:ObjectProperty ;
    rdfs:label "has interaction intent concept" ;
    rdfs:comment "Intent underlying the interaction (e.g., explain, request, negotiate)."@en ;
    rdfs:domain hi:Interaction ;
    rdfs:range skos:Concept .

hi:hasInteractionModalityConcept a owl:ObjectProperty ;
    rdfs:label "has interaction modality concept" ;
    rdfs:comment "Modality/channel used during the interaction."@en ;
    rdfs:domain hi:Interaction ;
    rdfs:range skos:Concept .

hi:hasMethod a owl:ObjectProperty ;
    rdfs:label "has method" ;
    rdfs:comment "A model uses a specific method."@en ;
    rdfs:domain hi:Model ;
    rdfs:range hi:Method .

hi:hasMethodConcept a owl:ObjectProperty ;
    rdfs:label "has method concept" ;
    rdfs:comment "Links a task execution to a method in the HINT thesaurus."@en ;
    rdfs:domain hi:Method ;
    rdfs:range skos:Concept .

hi:hasMetricConcept a owl:ObjectProperty ;
    rdfs:label "has metric concept" ;
    rdfs:comment "An evaluation uses certain metrics, defined in the HINT thesaurus"@en,
        "Links a metric to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Evaluation,
        hi:Metric ;
    rdfs:range skos:Concept .

hi:hasMetricTested a owl:ObjectProperty ;
    rdfs:label "has metric tested" ;
    rdfs:comment "An experiment tests certain metrics."@en ;
    rdfs:domain hi:Experiment ;
    rdfs:range hi:Metric .

hi:hasNullHypothesis a owl:DatatypeProperty ;
    rdfs:label "has null hypothesis"@en ;
    rdfs:comment "Stores the textual formulation of the null hypothesis of an experiment."@en ;
    rdfs:domain hi:Experiment ;
    rdfs:range xsd:string .

hi:hasOutputData a owl:ObjectProperty ;
    rdfs:label "has output data" ;
    rdfs:comment "A model or task execution produces specific output data."@en ;
    rdfs:domain hi:Model,
        hi:TaskExecution ;
    rdfs:range hi:Data .

hi:hasPhenomenonConcept a owl:ObjectProperty ;
    rdfs:label "has phenomenon concept" ;
    rdfs:comment "Context exhibits a phenomenon (e.g., bias/feedback emerges in that context)."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hi:Context hi:HITeam hi:Agent ) ] ;
    rdfs:range skos:Concept .

hi:hasRoleConcept a owl:ObjectProperty ;
    rdfs:label "has role concept" ;
    rdfs:comment "Links a role to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Agent ;
    rdfs:range skos:Concept .

hi:hasTaskConcept a owl:ObjectProperty ;
    rdfs:label "has task concept" ;
    rdfs:comment "Links a task to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Task ;
    rdfs:range skos:Concept .

hi:hasUseCaseConcept a owl:ObjectProperty ;
    rdfs:label "has use case concept" ;
    rdfs:comment "Links a use case to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:UseCase ;
    rdfs:range skos:Concept .

hi:isInfluencedBy a owl:ObjectProperty ;
    rdfs:label "is influenced by" ;
    rdfs:comment "Related a HI Team to the contextual condition that affects its actions, collaboration dynamics, or task performance."@en ;
    rdfs:domain hi:HITeam ;
    rdfs:range hi:Context ;
    owl:inverseOf hi:hasInfluenceOn .

hi:operatesInContext a owl:ObjectProperty ;
    rdfs:label "operates in context" ;
    rdfs:comment "Specifies the context in which an HI team operates."@en ;
    rdfs:domain hi:Agent ;
    rdfs:range hi:Context .

hi:performedBy a owl:ObjectProperty ;
    rdfs:label "performed by" ;
    rdfs:comment "Execution performed by an agent."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hi:TaskExecution ) ] ;
    rdfs:range hi:Agent ;
    owl:inverseOf hi:performsExecution .

hi:realizedBy a owl:ObjectProperty ;
    rdfs:label "realized by" ;
    rdfs:comment "A task is realized through a task execution."@en ;
    rdfs:domain hi:Task ;
    rdfs:range hi:TaskExecution ;
    owl:inverseOf hi:realizesTask .

hi:towardsGoal a owl:ObjectProperty ;
    rdfs:label "towards goal" ;
    rdfs:comment "Task execution towards a goal."@en ;
    rdfs:domain hi:TaskExecution ;
    rdfs:range hi:Goal .

hi:usesModel a owl:ObjectProperty ;
    rdfs:label "uses model" ;
    rdfs:comment "Indicates that a task execution uses a specific model (e.g., a language model developed by an organization) in its operation."@en ;
    rdfs:domain hi:TaskExecution ;
    rdfs:range hi:Model .

hi:AgentBasedSocialSimulationMethod a hi:Method ;
    rdfs:label "Agent-based social simulation"@en ;
    owl:sameAs dbr:Agent-based_social_simulation,
        wd:Q619754 .

hi:AlexLearningSupportTeam a hi:HITeam ;
    hi:hasGoal hi:SupportPersonalizedLearningGoal ;
    hi:hasMember hi:Alex,
        hi:AssistiveRobot,
        hi:TeacherUser,
        hi:Therapist ;
    hi:isInfluencedBy hi:PersonalizedLearningContext .

hi:AlphaFoldPredictionModel a hi:Model ;
    rdfs:label "AlphaFold prediction model"@en ;
    hi:hasInputData hi:ProteinSequenceDataset ;
    hi:hasMethod hi:ProteinStructurePredictionMethod ;
    hi:hasOutputData hi:PredictedProteinStructureData .

hi:ArchivalCurationTeam a hi:HITeam ;
    rdfs:label "Archival curation team"@en ;
    hi:hasGoal hi:PreserveAndCurateArchivalKnowledgeGoal ;
    hi:hasMember hi:ArchivalFootageAISystem,
        hi:CulturalHeritageSteward ;
    hi:isInfluencedBy hi:ArchivalCurationContext .

hi:ArchivalSegmentationModel a hi:Model ;
    rdfs:label "Archival segmentation model"@en ;
    hi:hasInputData hi:ArchivalFootageDataset ;
    hi:hasMethod hi:MultimodalSegmentationMethod ;
    hi:hasOutputData hi:TaggedArchivalSegments .

hi:ArchiveVideoSegmentationExecution a hi:TaskExecution ;
    rdfs:label "Archive video segmentation execution"@en ;
    hi:hasInputData hi:ArchivalFootageDataset ;
    hi:hasInteractionEpisode hi:ArchivalGovernanceInteraction ;
    hi:hasOutputData hi:TaggedArchivalSegments ;
    hi:performedBy hi:ArchivalFootageAISystem ;
    hi:realizesTask hi:ArchiveVideoSegmentationTask ;
    hi:towardsGoal hi:PreserveAndCurateArchivalKnowledgeGoal ;
    hi:usesModel hi:ArchivalSegmentationModel .

hi:BiometricsAndForensicsDomain a hi:Domain ;
    rdfs:label "Biometrics and forensics"@en ;
    owl:sameAs dbr:Biometrics,
        wd:Q207476 .

hi:BlockSuspiciousTrafficExecution a hi:TaskExecution ;
    rdfs:label "Blocking suspicious traffic execution"@en ;
    hi:evaluatedBy hi:CybersecurityResponseEvaluation ;
    hi:hasInteractionEpisode hi:CybersecurityThreatReviewInteraction ;
    hi:performedBy hi:AISecuritySystem ;
    hi:realizesTask hi:BlockSuspiciousTrafficTask ;
    hi:towardsGoal hi:ImproveCybersecurityResponseGoal .

hi:BrainAgeAssessmentExecution a hi:TaskExecution ;
    rdfs:label "Brain age assessment execution"@en ;
    hi:evaluatedBy hi:BrainAgeEvaluation ;
    hi:hasInputData hi:BrainImagingData ;
    hi:hasInteractionEpisode hi:BrainAgeInterpretationInteraction ;
    hi:hasOutputData hi:BrainAgePredictionOutput ;
    hi:performedBy hi:BrainAgeSupportSystem ;
